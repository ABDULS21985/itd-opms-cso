# ──────────────────────────────────────────────
# ITD-OPMS API Configuration
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=opms
DB_PASSWORD=opms_secret
DB_NAME=itd_opms
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MinIO (S3-compatible Object Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=opms_minio
MINIO_SECRET_KEY=opms_minio_secret
MINIO_USE_SSL=false
MINIO_BUCKET_EVIDENCE=evidence-vault
MINIO_BUCKET_ATTACHMENTS=attachments

# NATS JetStream
NATS_URL=nats://localhost:4222

# JWT Auth (dev mode — will be replaced by Entra ID OIDC)
JWT_SECRET=dev-secret-change-in-production-minimum-32-chars!!
JWT_EXPIRY=30m
JWT_REFRESH_EXPIRY=168h

# Entra ID (for Prompt 2 — Microsoft 365 Integration)
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# ENTRA_REDIRECT_URI=http://localhost:3000/auth/callback

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_SERVICE_NAME=itd-opms-api

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
