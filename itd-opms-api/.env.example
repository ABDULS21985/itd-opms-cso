# ──────────────────────────────────────────────
# ITD-OPMS API Configuration
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8089
SERVER_ENV=production

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=opms
DB_PASSWORD=           # REQUIRED — use a strong password
DB_NAME=itd_opms
DB_SSLMODE=require
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MinIO (S3-compatible Object Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=      # REQUIRED
MINIO_SECRET_KEY=      # REQUIRED
MINIO_USE_SSL=true
MINIO_BUCKET_EVIDENCE=evidence-vault
MINIO_BUCKET_ATTACHMENTS=attachments

# NATS JetStream
NATS_URL=nats://localhost:4222

# JWT Auth
JWT_SECRET=            # REQUIRED — generate with: openssl rand -base64 48
JWT_EXPIRY=30m
JWT_REFRESH_EXPIRY=168h

# Entra ID / Microsoft 365 Integration
ENTRA_ENABLED=false
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=https://your-domain.com/auth/callback

# Microsoft Graph API
GRAPH_SERVICE_ACCOUNT_ID=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_SERVICE_NAME=itd-opms-api

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
